<h1 class="form-title"><%= t('auth.login_title') %></h1>

<%= form_with url: login_path, local: true, html: { class: "auth-form" } do |form| %>
  <div class="form-group">
    <%= form.label :email, t('auth.email') %>
    <%= form.email_field :email, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= form.label :password, t('auth.password') %>
    <%= form.password_field :password, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= form.submit t('auth.submit_login'), class: "form-submit" %>
  </div>
<% end %>

<%= link_to t('auth.link_no_account'), register_path, class: "enlace-derecha" %>

