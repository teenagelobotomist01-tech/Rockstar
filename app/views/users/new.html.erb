<h1 class="form-title">Registrarse</h1>

<%= form_with model: @user, url: register_path, local: true, html: { class: "auth-form" } do |form| %>
  <div class="form-group">
    <%= form.label :name, "Nombre" %>
    <%= form.text_field :name, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= form.label :email, "Correo electrónico" %>
    <%= form.email_field :email, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= form.label :password, "Contraseña" %>
    <%= form.password_field :password, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= form.label :password_confirmation, "Confirmar contraseña" %>
    <%= form.password_field :password_confirmation, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= form.submit "Crear cuenta", class: "form-submit" %>
  </div>
<% end %>

<li><%= link_to "ya tengo una cuenta", login_path %></li>
