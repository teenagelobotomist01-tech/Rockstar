<h1>Bienvenido, <%= @user.name %></h1>
<p>Email: <%= @user.email %></p>
<% if current_user.survey.present? %>
  <p>Gracias por responder la encuesta.</p>
<% else %>
  <%= link_to "Responder encuesta", new_survey_path %>
<% end %>

<%= button_to "Cerrar sesión", logout_path, method: :delete, class: "btn btn-danger" %>
